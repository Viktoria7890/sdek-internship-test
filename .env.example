# =============================================================
# ВАРИАНТ 1 — OpenAI (лучшее качество, требует API-ключ)
# Получить ключ: https://platform.openai.com/api-keys
# =============================================================
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-ваш-ключ-здесь
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================
# ВАРИАНТ 2 — Ollama (локально, без API-ключей, бесплатно)
# Модели скачиваются автоматически при первом docker-compose up
# =============================================================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================
# Дополнительно: кастомный OpenAI-совместимый endpoint
# (Azure OpenAI, прокси и т.д.)
# =============================================================
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/
